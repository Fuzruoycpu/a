function decode(inputString)
	if inputString=="" or inputString==nil then return nil else
		local parts = {}
		for part in string.gmatch(inputString, "([^;]+)") do
			table.insert(parts, part)
		end
		return parts[1]
	end
end
function sdc(at:animationTrack,side:boolean)
	if ply.Character.Humanoid.FloorMaterial~=Enum.Material.Air then ply.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
	wait(.02)
	at:Stop()
	local hrp=ply.Character.HumanoidRootPart
	local part = Instance.new("Part",workspace)
	part.Anchored = true
	part.CanCollide = false
	part.Transparency = 1
	if side then
		part.CFrame = hrp.CFrame * CFrame.new(40,0,0)
	else
		part.CFrame = hrp.CFrame * CFrame.new(-40,0,0)
	end
	local hy=hrp.AssemblyLinearVelocity.Y
	hrp.AssemblyLinearVelocity = (part.Position-hrp.Position).Unit*Vector3.new(dd,0,dd)
	hrp.AssemblyLinearVelocity=Vector3.new(hrp.AssemblyLinearVelocity.X, hy, hrp.AssemblyLinearVelocity.Z)
	part:Destroy()
end 
function fDash()
    local ply = ply.Character
    local chr = ply:GetAttribute("Character")
    local hrp = ply:FindFirstChild("HumanoidRootPart")
    local h = ply:FindFirstChild("Humanoid")
    if hrp and h then
        local target=ply:GetAttribute("LastM1Hitted")
        aded=true
        local fp = Instance.new("Part",workspace)
        fp.Anchored=true
        fp.CanCollide = false
        fp.Transparency = 1
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://10480793962"

        local attach = Instance.new("Attachment",hrp)

        local LinearVelocity = Instance.new("LinearVelocity",attach)

        local part = Instance.new("Part",workspace)
        part.Anchored = true
        part.CanCollide = false
        part.Transparency = 0
        if chr=="Ninja" then
            part.CFrame = hrp.CFrame * CFrame.new(40,0,0)
            fp.CFrame = hrp.CFrame * CFrame.new(40,0,0)
        else
            part.CFrame = hrp.CFrame * CFrame.new(30,0,0)
            fp.CFrame = hrp.CFrame * CFrame.new(30,0,0)
        end
        local animplay:AnimationTrack = h:LoadAnimation(anim)
        animplay:Play(0,10,1)

        LinearVelocity.MaxForce = 9999999
        LinearVelocity.VectorVelocity = (part.Position-hrp.Position).Unit*Vector3.new(150,0,150)
        LinearVelocity.Attachment0 = attach
        task.wait(0.15)
        attach:Destroy()
        part:Destroy()
        LinearVelocity:Destroy()
        aded=false
        wait(.05)
        ply.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
        ply.HumanoidRootPart.CFrame=fp.CFrame*CFrame.Angles(0,math.rad(80),0)
        fp:Destroy()
        task.wait(0.05)
        vim:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
        vim:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
        local look = decode(target)
        if look ~=nil then
            local vp1 = workspace.Live:FindFirstChild(look)
            vp1=vp1.PrimaryPart
            for i = 1, 100 do
                hrp.CFrame = CFrame.lookAt(hrp.Position,Vector3.new(vp1.Position.X,hrp.Position.Y,vp1.Position.Z))
                task.wait()
            end
        end
    end
end
function lookUp(hrp:BasePart,thrp:BasePart)
	local absxz = math.abs((hrp.Position - thrp.Position).Magnitude)
	if absxz>=idk and absxz < 12.5 then
        hrp.CFrame =CFrame.lookAt(hrp.Position,Vector3.new(thrp.Position.X,hrp.Position.Y+addY,thrp.Position.Z))
	elseif math.abs(hrp.Position.Y-thrp.Position.Y)>8 then
		hrp.Velocity-=Vector3.new(0,5,0)
	end
end

