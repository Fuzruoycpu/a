function LightningStrike(ply)
	
	local hrp:Part=workspace.Live:FindFirstChild(ply)
	if not hrp then return nil end
	hrp= hrp:FindFirstChild('HumanoidRootPart')
	if not hrp then return nil end

	local Start = hrp.Position-Vector3.new(0,3,0)
	local End = hrp.Position+Vector3.new(0,500,0)
	local Points = 10

	local Offset = 20
	local DelayTime = 0
	local BoltTweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out);

	local Width0 = 2
	local Width1 = 0

	local Trans0 = 0
	local Trans1 = 0

	local Duration = 0.25

	local Colors = {Color3.fromRGB(100, 200, 255)}
	local EndColors = {Color3.fromRGB(200, 255, 255)}

	local ColorsAffectWholeBolt = true
	local BoltColorStatic = false

	local Bolt = Bolt:Clone()

	local BoltParent = Instance.new("Model", workspace)

	--- Main ---

	local SegmentPoints = {
		[0] = Start
	}

	local SegmentDistance = (End - Start) / Points
	local LastPosition = Start

	local StartSegmentPart = Bolt:Clone()

	StartSegmentPart.Transparency = 1
	StartSegmentPart.Parent = BoltParent
	StartSegmentPart.Position = LastPosition
	Debris:AddItem(StartSegmentPart, 0.1)
	Debris:AddItem(BoltParent, Duration+(Points*DelayTime))

	for i = 1,Points do
		local Position = (i == Points and End) or (LastPosition + SegmentDistance)
		local Offset = CFrame.new(Vector3.new(Random.new():NextNumber(-Offset, Offset), Random.new():NextNumber(-Offset, Offset), 0))

		local NewPosition = Position+Offset.Position

		LastPosition = Position
		SegmentPoints[i] = (i == Points and End) or NewPosition
	end

	local BaseRandomColor = Colors[math.random(1, #Colors)]
	local BaseRandomColorEnd = EndColors[math.random(1, #EndColors)]

	for i = 1,Points do
		local PreviousPoint: Vector3 = SegmentPoints[i-1]
		local NextPoint: Vector3 = SegmentPoints[i]

		local Distance = (PreviousPoint - NextPoint).Magnitude

		local Segment = Bolt:Clone()
		Segment.Parent = BoltParent		
		Segment.CFrame = CFrame.lookAt(PreviousPoint, NextPoint)*CFrame.new(Vector3.new(0,0,-Distance/2))
		Segment.Color = (ColorsAffectWholeBolt and BaseRandomColor) or Colors[math.random(1, #Colors)]
		Segment.Transparency = Trans0

		Segment.Size = Vector3.new(Width0, Width0, Distance)
		Tween(Segment, BoltTweenInfo, {Size = Vector3.new(Width1, Width1, Distance), Transparency = Trans1})
		if not BoltColorStatic then Tween(Segment, TweenInfo.new(Duration, Enum.EasingStyle.Linear), {Color = (ColorsAffectWholeBolt and BaseRandomColorEnd) or EndColors[math.random(1, #EndColors)]}) end

		if DelayTime > 0 then
			task.wait(DelayTime)
		end

		Debris:AddItem(Segment, Duration)
	end

end
function chrloaded(chr)
    if chr:GetAttribute("Character")=="Monster" then
    	dd=145
    elseif chr:GetAttribute("Character")=="Bald" then
    	dd=125
    else
    	dd=135
    end
    if animconnection then
        animconnection:Disconnect()
    end
	if attributeconnection then
		attributeconnection:Disconnect()
	end
	if hrpChildAddedCon then
		hrpChildAddedCon:Disconnect()
	end
    animconnection = chr.Humanoid.AnimationPlayed:Connect(function(at: AnimationTrack)
    	aimbotanim(at)
		local animId = at.Animation.AnimationId
    	if animId == "rbxassetid://10480796021" then 
    		if mrtoggle and emoteDashToggle and not aded then 
                sdc(at,false)
            end
    	elseif animId == "rbxassetid://10480793962" then 	
            if mrtoggle and emoteDashToggle and not aded then
    		    sdc(at,true)
            end
    	elseif animId=='rbxassetid://13813955149' and tcanboostToggle then
			tcanthrowdetected=true
			at.Stopped:Connect(function()
				tcanthrowdetected=false
			end)
			while task.wait() do
				if not tcanthrowdetected then break end
				game.RunService.Heartbeat:Wait()
				local character = chr
				local root = chr.HumanoidRootPart
				local vel, movel = nil, 0.1

				vel = ((root.CFrame*CFrame.new(0,0,200)).Position-root.Position).Unit
				root.Velocity = vel * -tcanboostpower

				game.RunService.RenderStepped:Wait()
				if character and character.Parent and root and root.Parent then
					root.Velocity = vel
				end

				game.RunService.Stepped:Wait()
				if character and character.Parent and root and root.Parent then
					root.Velocity = vel + Vector3.new(0, movel, 0)
					movel = movel * -1
				end
			end
		elseif at.Animation.AnimationId=='rbxassetid://11343250001' and antideathcounter then
			at:Stop()
			local hrp=chr.HumanoidRootPart
			local pos=hrp.CFrame
			task.wait(3)
			for a=1,75 do task.wait()
			hrp:PivotTo(CFrame.new(0, workspace.FallenPartsDestroyHeight+1, 0)*CFrame.Angles(math.rad(90),0,0))
			hrp.Velocity=Vector3.new(0, 0, 0)
			end
			task.wait(0.5)
			hrp.CFrame=pos
			workspace.CurrentCamera:Destroy()
			task.wait(0.1)
			workspace.CurrentCamera.CameraSubject = chr:FindFirstChildWhichIsA('Humanoid')
			workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
			ply.CameraMinZoomDistance = 0.5
			ply.CameraMaxZoomDistance = 400
			ply.CameraMode = "Classic"
			ply.PlayerGui.Death:Destroy()
			chr:FindFirstChild("NoRotateUltimate"):Destroy()
			chr:FindFirstChild("NoRotate"):Destroy()
		end
    end)
	attributeconnection = chr.AttributeChanged:Connect(function(attr)
		if attr=='StrongerM1' and blockdodgeToggle then
			local att = chr:GetAttribute("StrongerM1")
			if att == false then return end
			if chr:FindFirstChild('M1ing')then return end
			loadanim(anims[math.random(1, 4)]):Play()
		end
		if attr=='LastM1Hitted' then
			local a=decode(chr:GetAttribute('LastM1Hitted'))
			a=workspace.Live:FindFirstChild(a)
			if hitmarkerToggle then
			local cgui = hitmarkgui:Clone()
			cgui.Parent=a.Head
			playsound(125235091454234)
			task.wait(0.1)
			cgui:Destroy()
			end
			if StrikeToggle then
				LightningStrike(a.Name)
			end
		end
	end)
	hrpChildAddedCon = chr.HumanoidRootPart.ChildAdded:Connect(function(part)
		if part.Name=='moveme' and part:IsA("BodyVelocity") then
			if not dashboostToggle then return end
			part:SetAttribute('Speed',dashboostpower)
		end
	end)
end
